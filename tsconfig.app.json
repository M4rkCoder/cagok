{
  "compilerOptions": {
    "target": "ESNext",
    "downlevelIteration": true,
    "module": "esnext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "types": ["node", "@tauri-apps/api"],
    "moduleResolution": "node"
  },
  "include": ["src"]
}
