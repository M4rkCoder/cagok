{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "finkro",
  "version": "0.1.0",
  "identifier": "finkro",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "sql": {},
    "opener": {}
  },
  "app": {
    "windows": [
      {
        "title": "FINKRO",
        "width": 1400,
        "height": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["window"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
