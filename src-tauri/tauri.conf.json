{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CAGOK",
  "version": "1.0.0",
  "identifier": "StackLogic.CAGOK",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "sql": {},
    "opener": {}
  },
  "app": {
    "windows": [
      {
        "title": "C'AGOK",
        "width": 600,
        "height": 500,
        "visible": false,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["window"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "C'AGOK STUDIO",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
